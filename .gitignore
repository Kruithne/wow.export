# nodejs modules (root and nested, e.g. native addon deps)
node_modules/

# Output directory for builds.
/bin
/publish

# Native addon build output (generated by build-native-addons.js)
node_addons/**/build/

# Temporary Spout SDK extraction (SDK is vendored under node_addons/spout/)
/_spout_tmp

# IDE configuration.
/.vscode
/.idea

# Runtime directory for tests.
/tests/user_data

# python cache folders
__pycache__